# ─────────────────────────────────────────────────────────
# AstroAI India — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to GitHub.
# ─────────────────────────────────────────────────────────

# ── Firebase Client (Public — safe to expose) ─────────────
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Firebase Admin (Private — server only) ────────────────
# Go to Firebase Console → Project Settings → Service Accounts
# → Generate new private key → paste the entire JSON as one line
FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Anthropic Claude API ──────────────────────────────────
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Redis (Use Upstash for Vercel — free tier available) ──
# Get from https://upstash.com → Create Redis → Copy URL
REDIS_URL=rediss://default:password@hostname:6379

# ── Razorpay (India Payments) ─────────────────────────────
# Get from https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Google Maps (Geocoding for birth place) ───────────────
# Get from https://console.cloud.google.com → Enable Geocoding + Timezone APIs
GOOGLE_MAPS_API_KEY=AIzaSy...

# ── App Config ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://astroai.in
NEXT_PUBLIC_APP_NAME=AstroAI India
